@app.post("/api/query", response_model=QueryResponse)
@limiter.limit("20/minute")
async def query(
    request: Request,
    body: SecureQueryRequest,
    user: dict = Depends(require_user),
):
    """Process a question through the RAG engine (authenticated + validated)."""
    global rag_engine

    if rag_engine is None:
        raise HTTPException(
            status_code=503,
            detail="RAG engine not initialised. Ingest documents first via /api/ingest.",
        )

    try:
        logger.info(f"[{user['username']}] Query: {body.question[:120]}...")
        result = rag_engine.query(body.question)

        # Sanitise output (XSS prevention)
        sources = [
            SourceInfo(
                filename=sanitize_output(s.get("filename", "Unknown")),
                document_type=sanitize_output(s.get("document_type", "pdf")),
                excerpt=sanitize_output(s.get("excerpt", "")),
            )
            for s in result.get("sources", [])
        ]

        return QueryResponse(
            answer=result.get("answer", ""),
            sources=sources,
        )

    except Exception as e:
        logger.error(f"Query failed: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="An internal error occurred.")


@app.post("/api/upload")
@limiter.limit("10/minute")
async def upload_files(
    request: Request,
    files: List[UploadFile] = File(...),
    user: dict = Depends(require_user),
):
    """Upload one or more PDF files into the data/ directory (authenticated)."""
    data_dir = Path("data")
    data_dir.mkdir(parents=True, exist_ok=True)

    # Input validation: filename sanitisation
    SAFE_FILENAME = re.compile(r"^[\w\-. ]+\.pdf$", re.IGNORECASE)
    MAX_FILE_SIZE = 50 * 1024 * 1024  # 50 MB

    saved: List[str] = []
    for f in files:
        # Validate filename (XSS / path traversal prevention)
        if not f.filename or not SAFE_FILENAME.match(f.filename):
            raise HTTPException(
                status_code=400,
                detail=f"Invalid filename: {f.filename}. Only alphanumeric PDF names allowed.",
            )

        # Read and check size
        content = await f.read()
        if len(content) > MAX_FILE_SIZE:
            raise HTTPException(
                status_code=413,
                detail=f"File too large: {f.filename} ({len(content)} bytes > {MAX_FILE_SIZE}).",
            )

        # Validate PDF magic bytes
        if not content[:5].startswith(b"%PDF-"):
            raise HTTPException(
                status_code=400,
                detail=f"File does not appear to be a valid PDF: {f.filename}",
            )

        dest = data_dir / f.filename
        with open(dest, "wb") as buf:
            buf.write(content)
        saved.append(f.filename)
        logger.info(f"[{user['username']}] Uploaded: {f.filename}")

    return {"status": "ok", "files": saved}


@app.get("/api/documents")
@limiter.limit("30/minute")
async def list_documents(
    request: Request,
    user: dict = Depends(require_user),
):
    """List PDF files currently in the data/ folder (authenticated)."""
    data_dir = Path("data")
    if not data_dir.exists():
        return {"files": []}
    files = [
        {"name": f.name, "size_kb": round(f.stat().st_size / 1024, 1)}
        for f in sorted(data_dir.iterdir())
        if f.suffix.lower() == ".pdf"
    ]
    return {"files": files}


@app.post("/api/ingest", response_model=IngestResponse)
@limiter.limit("5/minute")
async def ingest_documents(
    request: Request,
    user: dict = Depends(require_admin),
):
    """Run ingestion pipeline (admin-only, authenticated)."""
    global rag_engine

    try:
        ingestor = NeuraVaultIngestor()

        raw_docs = ingestor.load_pdf_documents()
        doc_objects = ingestor.create_documents_with_metadata(raw_docs)
        split_docs = ingestor.split_documents(doc_objects)
        ingestor.create_vector_store(split_docs)

        rag_engine = initialize_rag_engine(
            vector_db_dir="vector_db",
            model_name="llama3.2",
        )

        logger.info(
            f"[{user['username']}] Ingestion complete: "
            f"{len(raw_docs)} doc(s), {len(split_docs)} chunk(s)"
        )

        return IngestResponse(
            status="ok",
            documents_processed=len(raw_docs),
            chunks_created=len(split_docs),
        )

    except FileNotFoundError as e:
        raise HTTPException(status_code=404, detail=str(e))
    except Exception as e:
        logger.error(f"Ingestion failed: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="Ingestion failed.")
